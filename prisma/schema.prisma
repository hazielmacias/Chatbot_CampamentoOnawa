generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Contact {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  phone          String   @unique
  name           String?
  firstContactAt DateTime @default(now()) @map("first_contact_at")
  lastMessageAt  DateTime @default(now()) @map("last_message_at")
  status         String   @default("active")
  isEscalated    Boolean  @default(false) @map("is_escalated")
  isInterested   Boolean  @default(false) @map("is_interested")
  messages       Message[]
  escalations    Escalation[]
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @default(now()) @map("updated_at")

  @@map("onawa_contacts")
}

model Message {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contactId   String   @map("contact_id") @db.Uuid
  contact     Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  direction   String
  content     String
  messageType String   @default("text") @map("message_type")
  timestamp   DateTime @default(now())
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("onawa_messages")
}

model Escalation {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  contactId       String   @map("contact_id") @db.Uuid
  contact         Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  reason          String
  escalatedAt     DateTime @default(now()) @map("escalated_at")
  advisorNotified Boolean  @default(false) @map("advisor_notified")
  advisorPhone    String?  @map("advisor_phone")
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("onawa_escalations")
}

model DashboardUser {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  username     String   @unique
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @map("updated_at")

  @@map("onawa_dashboard_users")
}
