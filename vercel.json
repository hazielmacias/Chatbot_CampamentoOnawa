{
  "version": 2,
  "buildCommand": "npm run build",
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "dashboard/**",
      "use": "@vercel/static"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/dashboard/stats",
      "dest": "/api/dashboard/stats.js"
    },
    {
      "src": "/api/dashboard/conversations",
      "dest": "/api/dashboard/conversations.js"
    },
    {
      "src": "/api/dashboard/conversation",
      "dest": "/api/dashboard/conversation.js"
    },
    {
      "src": "/api/webhook",
      "dest": "/api/webhook.js"
    },
    {
      "src": "/dashboard",
      "dest": "/dashboard/index.html"
    },
    {
      "src": "/dashboard/(.*)",
      "dest": "/dashboard/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
